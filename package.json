{
  "name": "domaine-product-card",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "scripts": {
    "tw:dev": "tailwindcss -i ./assets/tailwind.input.css -o ./assets/tailwind.output.css --watch",
    "tw:build": "tailwindcss -i ./assets/tailwind.input.css -o ./assets/tailwind.output.css --minify",
    "shopify:dev": "shopify theme dev -e dev",
    "shopify:dev:sync": "shopify theme dev -e dev --theme-editor-sync",
    "shopify:pull": "shopify theme pull -e dev",
    "shopify:push": "shopify theme push -e dev"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.3.2",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@shopify/cli": "^4.3.0"
  }
}
