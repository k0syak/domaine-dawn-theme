{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<script src="{{ 'product-card--custom.js' | asset_url }}" defer="defer"></script>

<div class="page-width tw:flex tw:justify-left tw:px-4 section-{{ section.id }}-padding">
  {%- if section.settings.product != blank -%}
    {% render 'card-product--custom', card_product: section.settings.product, show_add_to_cart: section.settings.show_add_to_cart %}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.custom-product-card.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.custom-product-card.settings.header__product.content"
    },
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.custom-product-card.settings.product.label"
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "t:sections.custom-product-card.settings.show_add_to_cart.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom-product-card.presets.name",
      "category": "t:sections.custom-product-card.presets.category"
    }
  ]
}
{% endschema %}